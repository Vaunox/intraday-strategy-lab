# Kite Connect credentials — COPY THIS FILE TO .env AND FILL IN YOUR OWN VALUES.
#
#   cp .env.example .env      # .env is git-ignored (see .gitignore) — NEVER commit it
#
# Never paste these values into chat, code, config, tickets, or git. If a secret
# is ever exposed, regenerate it in the Kite developer console (My Apps).

# From the Kite developer console (My Apps -> your app):
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# The daily access token is minted by scripts/kite_login.py and saved to a
# git-ignored file — do NOT set it here by hand. Leave blank.
KITE_ACCESS_TOKEN=
